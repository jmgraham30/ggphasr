result <- gg_phase_plane(
  ode_logistic,
  xlim       = c(0, 8),
  ylim       = c(-1, 12),
  system     = "one.dim",
  parameters = c(r = 1, K = 10)
)
result$plot

# Suppress equilibrium search for speed
result <- gg_phase_plane(
  ode_van_der_pol,
  xlim            = c(-3, 3),
  ylim            = c(-4, 4),
  parameters      = c(mu = 1),
  find_equilibria = FALSE,
  t_end           = 20
)
result$plot

