# Minimal call: produces everything automatically
result <- gg_phase_plane(
  ode_lotka_volterra,
  xlim       = c(0, 5),
  ylim       = c(0, 5),
  parameters = c(alpha = 1, beta = 0.5, delta = 0.5, gamma = 1)
)
result$plot
result$equilibria[, c("x", "y", "classification")]

