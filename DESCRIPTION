Package: ggphasr
Title: Phase Plane Analysis of ODE Systems Using ggplot2
Version: 0.0.0.9000
Authors@R:
    person(
      given   = "Jason",
      family  = "Graham",
      email   = "prof.jason.m.graham@gmail.com",
      role    = c("aut", "cre"),
      comment = c(ORCID = "0000-0003-0047-7178")
